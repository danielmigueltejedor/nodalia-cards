{
  "name": "nodalia-cards",
  "version": "1.1.0-alpha.16",
  "packageManager": "pnpm@11.1.1",
  "private": false,
  "type": "module",
  "description": "Suite de tarjetas personalizadas de Home Assistant para Nodalia.",
