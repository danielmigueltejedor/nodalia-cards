    "i18n/editor/el.json",
    "i18n/editor/en.json",
    "i18n/editor/es.json",
    "i18n/editor/fr.json",
    "i18n/editor/it.json",
    "i18n/editor/nl.json",
    "i18n/editor/no.json",
    "i18n/editor/pt.json",
    "i18n/editor/ro.json",
    "i18n/editor/ru.json",
    "i18n/editor/zh.json",
    "README.md",
    "hacs.json",
    "examples"
